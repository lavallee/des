{
  "name": "@lavallee/des",
  "version": "0.4.0",
  "description": "Design system for the Lyra Forge tool family",
  "license": "MIT",
  "type": "module",
  "bin": {
    "des-audit": "scripts/des-audit.mjs"
  },
  "scripts": {
    "audit:showcase": "node scripts/des-audit.mjs --url http://127.0.0.1:4173/showcase.html --task 'Find and inspect a system pattern' --surface 'DES component showcase' --out artifacts/design-receipts/showcase",
    "test": "node --test"
  },
  "exports": {
    "./tokens.css": "./tokens.css",
    "./components.css": "./components.css",
    "./colors_and_type.css": "./colors_and_type.css",
    "./themes/carbon.css": "./themes/carbon.css",
    "./themes/slate.css": "./themes/slate.css",
    "./themes/parchment.css": "./themes/parchment.css"
  },
  "files": [
    "tokens.css",
    "components.css",
    "colors_and_type.css",
    "README.md",
    "PRACTICE.md",
    "PRINCIPLES.md",
    "PATTERNS-ADMIN.md",
    "RUBRIC.md",
    "SKILL.md",
    "docs/",
    "scripts/",
    "themes/",
    "assets/"
  ],
  "keywords": [
    "design-system",
    "css"
  ],
  "peerDependencies": {
    "agent-browser": ">=0.22.1"
  },
  "peerDependenciesMeta": {
    "agent-browser": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lavallee/des.git"
  }
}
